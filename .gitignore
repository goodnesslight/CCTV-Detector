# =========================================================
# Проектные данные времени выполнения
# =========================================================

# Скачанные веса моделей (~50 МБ, авто-докачиваются при первом запуске)
data/models/
*.pt
*.onnx

# Артефакты Ultralytics при дообучении моделей
runs/

# Скачанные датасеты (Roboflow обычно создаёт папку рядом)
*.zip
datasets/

# Секреты (Roboflow API key и пр.)
.env
.env.local

# Записанные клипы алертов (большие, могут содержать персональные данные)
data/clips/

# Загруженные пользователем фотографии whitelist'а лиц (персональные данные)
data/known_faces/

# Локальная БД событий (создаётся приложением)
data/events.db
data/events.db-journal
data/events.db-shm
data/events.db-wal

# Локальные пользовательские конфиги (создаются с дефолтами при отсутствии)
data/settings.json
data/zones.json

# =========================================================
# Логи установки / отладки
# =========================================================
*.log
install_*.log
